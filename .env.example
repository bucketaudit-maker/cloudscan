# ═══════════════════════════════════════════════════════════
# CloudScan Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=true

# ── Database ────────────────────────────────────────────────
# PostgreSQL (default for local and production)
DATABASE_URL=postgresql://cloudscan:cloudscan@localhost:5432/cloudscan

# For tests only (optional): SQLite
# DATABASE_URL=sqlite:///path/to/cloudscan.db

# Redis (for caching, rate limiting, WebSocket pub/sub)
REDIS_URL=redis://localhost:6379/0

# ── Scanner ─────────────────────────────────────────────────
SCANNER_CONCURRENCY=50
SCANNER_TIMEOUT=10
SCANNER_USER_AGENT=CloudScan/1.0 (Security Research)
SCANNER_MAX_FILES_PER_BUCKET=100000
RUN_DB_MIGRATIONS_ON_STARTUP=true
ENABLE_MONITOR_SCHEDULER=false
MONITOR_SCHEDULER_INTERVAL_SECONDS=300

# ── API ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
# Local: frontend origins for CORS. Production: set to your frontend URL (e.g. https://app.yourdomain.com)
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limits (requests per day)
RATE_LIMIT_FREE=100
RATE_LIMIT_PREMIUM=5000
RATE_LIMIT_ENTERPRISE=50000

# JWT
JWT_EXPIRATION_HOURS=24

# ── AI Providers ──────────────────────────────────────────
# Set AI_PROVIDER to your preferred default: anthropic, openai, google, ollama
# If unset, the first available provider (with a configured key) is auto-selected.
AI_PROVIDER=
AI_ENABLED=true
AI_MAX_FILES_PER_BATCH=200

# Anthropic Claude (https://console.anthropic.com/)
ANTHROPIC_API_KEY=
AI_MODEL_FAST=claude-haiku-4-5
AI_MODEL_QUALITY=claude-sonnet-4-6

# OpenAI (https://platform.openai.com/)
OPENAI_API_KEY=
OPENAI_MODEL_FAST=gpt-4o-mini
OPENAI_MODEL_QUALITY=gpt-4o

# Google Gemini (https://aistudio.google.com/)
GOOGLE_API_KEY=
GOOGLE_MODEL_FAST=gemini-2.0-flash
GOOGLE_MODEL_QUALITY=gemini-2.5-pro

# Ollama — local/open-source (no API key needed, just the URL)
# Start Ollama: ollama serve, then set the base URL below
OLLAMA_BASE_URL=
OLLAMA_MODEL_FAST=llama3.2
OLLAMA_MODEL_QUALITY=llama3.1:70b

# ── Frontend (optional) ─────────────────────────────────────
# Leave unset for local dev (Vite proxy) or when API is same host as UI.
# Set in production when API is on another host: https://api.yourdomain.com
# VITE_API_URL=http://localhost:8000
# VITE_API_URL=https://api.yourdomain.com
# VITE_PROXY_TARGET=http://localhost:8000   # dev only: Vite proxy target
# VITE_WS_URL=ws://localhost:8000
