# ═══════════════════════════════════════════════════════════
# CloudScan Configuration
# Copy this to .env and fill in your values
# ═══════════════════════════════════════════════════════════

# ── App ─────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=change-me-to-a-random-64-char-string
DEBUG=true

# ── Database ────────────────────────────────────────────────
# SQLite (default for development)
DATABASE_URL=sqlite:///data/cloudscan.db

# PostgreSQL (recommended for production)
# DATABASE_URL=postgresql://user:password@localhost:5432/cloudscan

# Redis (for caching, rate limiting, WebSocket pub/sub)
REDIS_URL=redis://localhost:6379/0

# ── Scanner ─────────────────────────────────────────────────
SCANNER_CONCURRENCY=50
SCANNER_TIMEOUT=10
SCANNER_USER_AGENT=CloudScan/1.0 (Security Research)
SCANNER_MAX_FILES_PER_BUCKET=100000

# ── API ─────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=8000
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Rate limits (requests per day)
RATE_LIMIT_FREE=100
RATE_LIMIT_PREMIUM=5000
RATE_LIMIT_ENTERPRISE=50000

# JWT
JWT_EXPIRATION_HOURS=24

# ── Frontend ────────────────────────────────────────────────
VITE_API_URL=http://localhost:8000
VITE_WS_URL=ws://localhost:8000
